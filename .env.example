# ============================================================
# synkolab-emergency — Environment Configuration
# cp .env.example .env แล้วแก้ค่าตามต้องการ
# ============================================================

# ---------- Server ----------
NODE_ENV=production
HOST=0.0.0.0
PORT=4000

# ---------- SSL ----------
SSL_ENABLED=true
SSL_CERT_PATH=/app/certs/fullchain.pem
SSL_KEY_PATH=/app/certs/privkey.pem

# ---------- Domain ----------
PUBLIC_URL=https://call.stu-link.com
ALLOWED_ORIGINS=https://comm-link.cmru.ac.th,https://call.stu-link.com,http://localhost:3000,http://localhost:5555

# ---------- Authentication ----------
# JWT secret — ต้องตรงกับ community-link (ใช้ openssl rand -hex 32)
JWT_SECRET=dev-secret-change-me-in-production-use-openssl-rand-hex-32
JWT_ISSUER=community-link
JWT_AUDIENCE=synkolab-emergency
JWT_EXPIRES_IN=2h

# API Key สำหรับ community-link server เรียก (comma-separated ถ้ามีหลาย key)
API_KEYS=sk_dev_change-me

# Secret สำหรับ verify Raspberry Pi device tokens
DEVICE_SECRET=dev-device-secret-change-me

# ---------- TURN Server ----------
TURN_SECRET=commlink-turn-secret-2026
TURN_SERVERS=turns:call.stu-link.com:5349,turn:call.stu-link.com:3478
TURN_TTL=86400

# ---------- Database ----------
DB_PATH=./data/emergency.db

# ---------- Redis (optional, สำหรับ multi-instance) ----------
REDIS_ENABLED=false
REDIS_URL=redis://redis:6379

# ---------- Rate Limiting ----------
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# ---------- WebSocket ----------
WS_PING_INTERVAL=30000
WS_AUTH_TIMEOUT=5000
WS_MAX_PAYLOAD=4096
WS_MAX_CONNECTIONS=500

# ---------- Call Settings ----------
CALL_RING_TIMEOUT=30000
CALL_MAX_DURATION=3600000

# ---------- LiveKit (SFU สำหรับ group/broadcast calls) ----------
# ถ้า false = ใช้ P2P อย่างเดียว, ถ้า true = ต้องมี LiveKit server
LIVEKIT_ENABLED=false
LIVEKIT_URL=ws://livekit:7880
LIVEKIT_PUBLIC_URL=wss://call.stu-link.com:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret123456789abcdef123456789abcdef
LIVEKIT_TOKEN_TTL=3600
LIVEKIT_DEVICE_TOKEN_TTL=86400

# ---------- Logging ----------
LOG_LEVEL=info
